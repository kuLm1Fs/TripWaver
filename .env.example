APP_NAME=TripWeaver
APP_ENV=local
LOG_LEVEL=INFO
API_PREFIX=/api/v1

# 搜索/LLM provider
SEARCH_PROVIDER=mock
LLM_PROVIDER=mock

# Tavily 搜索
TAVILY_API_KEY=

# 火山方舟 LLM
ARK_API_KEY=
ARK_MODEL=
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# PostgreSQL
DB_URL=postgresql+asyncpg://kms:123456@localhost:5432/tripweaver

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET=tripweaver-dev-secret-xxx
JWT_EXPIRE_HOURS=2

# CORS（逗号分隔，* 表示允许全部）
CORS_ORIGINS=["*"]

# 高德地图（可选）
AMAP_SERVER_KEY=
AMAP_JS_KEY=
